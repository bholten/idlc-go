package probe;

import engine.core.ManagedObject;
import system.util.Vector;
import system.util.VectorMap;
import system.lang.ref.Reference;

// Probe for the recursive generic-arg rendering rules.
//
// The JAR renders generic args differently based on the OUTER head:
//   - Smart-pointer wrappers (any name ending in `Reference`): inner
//     class arg becomes bare `X*`; inner generic arg gets `*`
//     appended after the close `>`.
//   - Container generics (Vector, VectorMap, SortedVector, ...): inner
//     class arg gets a Reference-wrap (`ManagedReference<X*>` for
//     IDL-managed, `Reference<X*>` for everything else); inner generic
//     arg passes through unchanged.
//
// Cases verified:
//   - Vector<primitive>                            (no wrap)
//   - Reference<ManagedClass>                      (smart-ptr leaf, managed → ManagedReference<X*>)
//   - VectorMap<int, Reference<ManagedClass>>      (container holding smart-ptr; container value-typed)
//   - Reference<Vector<int>>                       (smart-ptr holding container; trailing * after )
//   - Reference<Vector<Reference<ManagedClass>>>   (3-deep — every smart-ptr level honored)
//
// The .h field decls AND the .cpp TypeInfo<...>::parse/toBinaryStream
// lines both go through CppRenderFieldType, so a single rule covers
// both renderings.
class NestedGenerics extends ManagedObject {
	@dereferenced
	private Vector<unsigned long> primitiveVector;

	private Reference<ManagedObject> refToManaged;

	@dereferenced
	private VectorMap<int, Reference<ManagedObject> > mapWithRef;

	private Reference<Vector<int> > refToVector;

	private Reference<Vector<Reference<ManagedObject> > > threeDeep;
}
